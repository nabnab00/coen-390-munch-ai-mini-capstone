<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- LIGHT THEME -->
    <style name="Base.Theme.MunchAI" parent="Theme.Material3.Light.NoActionBar">

        <!-- Primary brand -->
        <item name="colorPrimary">@color/munch_bangladesh_green</item>
        <item name="colorOnPrimary">@color/munch_white</item>
        <item name="colorPrimaryContainer">@color/munch_mountain_meadow</item>
        <item name="colorOnPrimaryContainer">@color/munch_rich_black</item>

        <!-- Secondary / accents -->
        <item name="colorSecondary">@color/munch_frog</item>
        <item name="colorOnSecondary">@color/munch_white</item>
        <item name="colorSecondaryContainer">@color/munch_mint</item>
        <item name="colorOnSecondaryContainer">@color/munch_white</item>

        <!-- Backgrounds & surfaces -->
        <item name="android:colorBackground">@color/munch_anti_flash_white</item>
        <item name="colorOnBackground">@color/munch_rich_black</item>

        <item name="colorSurface">@color/munch_white</item>
        <item name="colorOnSurface">@color/munch_rich_black</item>

        <!-- Status / nav bars -->
        <item name="android:statusBarColor">@color/munch_dark_green</item>
        <item name="android:navigationBarColor">@color/munch_dark_green</item>

        <!-- Optional: default window background for normal screens -->
        <item name="android:windowBackground">@color/munch_anti_flash_white</item>
    </style>

    <!-- App theme alias -->
    <style name="Theme.MunchAI" parent="Base.Theme.MunchAI" />

</resources>

