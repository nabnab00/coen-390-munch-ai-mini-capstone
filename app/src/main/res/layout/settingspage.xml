<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="20dp"
    tools:context=".frontend.SettingsActivity"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- title -->
        <TextView
            android:id="@+id/settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:textColor="?android:attr/textColorPrimary"
            />

        <!-- darkmode/lightmode -->
        <Switch
            android:id="@+id/switch_darkmode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable Dark Mode"
            android:textSize="18sp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/brown_onBackground"
            />

        <!-- target calories -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Target Calories (kcal)"
            android:textSize="16sp"
            />

        <EditText
            android:id="@+id/settings_calories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="e.g. 2000"
            android:layout_marginBottom="16dp"
            android:textColor="@color/brown_onBackground"
            />

        <!-- target protein -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Target Protein (g)"
            android:textSize="16sp"
            />

        <EditText
            android:id="@+id/settings_protein"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="e.g. 100"
            android:layout_marginBottom="16dp"
            android:textColor="@color/brown_onBackground"
            />

        <!-- target carbs -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Target Carbohydrates (g)"
            android:textSize="16sp"
            />

        <EditText
            android:id="@+id/settings_carbohydrates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="e.g. 250"
            android:layout_marginBottom="16dp"
            android:textColor="@color/brown_onBackground"
            />

        <!-- target fat -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Target Fat (g)"
            android:textSize="16sp"
            />

        <EditText
            android:id="@+id/settings_fats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="e.g. 70"
            android:layout_marginBottom="24dp"
            android:textColor="@color/brown_onBackground"
            />

        <!-- save button -->
        <Button
            android:id="@+id/settings_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Settings"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:padding="10dp"
            android:backgroundTint="?attr/colorPrimary"
            android:textColor="@android:color/white"
            />

    </LinearLayout>
</ScrollView>
