<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp"
    tools:context=".frontend.SettingsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- 🔹 Back button (top-left) + Title + Save button (top-right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back"
                android:src="@drawable/ic_arrow_back"
                app:tint="?attr/colorOnSurface"
                tools:ignore="TouchTargetSizeCheck" />

            <TextView
                android:id="@+id/settings_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Settings"
                android:fontFamily="@font/outfit_semibold"
                android:textColor="?attr/colorPrimary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/settings_save"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="Save"
                android:textSize="18sp"
                android:fontFamily="@font/outfit_semibold"
                android:textColor="?attr/colorPrimary"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"/>

        </LinearLayout>

        <!-- darkmode/lightmode -->
        <Switch
            android:id="@+id/switch_darkmode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
            android:minHeight="48dp"
            android:text="Enable Dark Mode"
            android:fontFamily="@font/outfit_semibold"
            android:textColor="?attr/colorPrimary"
            android:textSize="18sp" />

        <!-- Target Macros Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="@color/munch_anti_flash_white"
            app:cardCornerRadius="14dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- target calories -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Target Calories (kcal)"
                    android:fontFamily="@font/outfit_semibold"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/settings_calories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@android:color/transparent"
                    android:hint="e.g. 2000"
                    android:inputType="number"
                    android:imeOptions="actionDone"
                    android:minHeight="48dp"
                    android:textColor="@color/brown_onBackground" />

                <!-- target protein -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Target Protein (g)"
                    android:fontFamily="@font/outfit_semibold"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/settings_protein"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@android:color/transparent"
                    android:hint="e.g. 100"
                    android:inputType="number"
                    android:imeOptions="actionDone"
                    android:minHeight="48dp"
                    android:textColor="@color/brown_onBackground" />

                <!-- target carbs -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Target Carbohydrates (g)"
                    android:fontFamily="@font/outfit_semibold"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/settings_carbohydrates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@android:color/transparent"
                    android:hint="e.g. 250"
                    android:inputType="number"
                    android:imeOptions="actionDone"
                    android:minHeight="48dp"
                    android:textColor="@color/brown_onBackground" />

                <!-- target fat -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Target Fat (g)"
                    android:fontFamily="@font/outfit_semibold"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/settings_fats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="e.g. 70"
                    android:inputType="number"
                    android:imeOptions="actionDone"
                    android:minHeight="48dp"
                    android:textColor="@color/brown_onBackground" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
