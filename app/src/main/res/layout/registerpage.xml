<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/munch_anti_flash_white"
    tools:context=".frontend.RegisterActivity">

    <LinearLayout
        android:id="@+id/register_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:id="@+id/register_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create your account"
            android:textColor="@color/munch_forest"
            android:textSize="24sp"
            android:fontFamily="@font/outfit_semibold"
            android:letterSpacing="0.02"
            android:layout_marginBottom="32dp" />

        <!-- Full Name -->
        <EditText
            android:id="@+id/register_fullname"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:hint="Name"
            android:inputType="textPersonName"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/munch_dark_green"
            android:textColorHint="@color/munch_stone"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginBottom="16dp"/>

        <!-- Age -->
        <EditText
            android:id="@+id/register_age"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:hint="Age"
            android:inputType="number"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/munch_dark_green"
            android:textColorHint="@color/munch_stone"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginBottom="16dp"/>

        <!-- Height -->
        <EditText
            android:id="@+id/register_height"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:hint="Height (cm)"
            android:inputType="numberDecimal"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/munch_dark_green"
            android:textColorHint="@color/munch_stone"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginBottom="16dp"/>

        <!-- Weight -->
        <EditText
            android:id="@+id/register_weight"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:hint="Weight (kg)"
            android:inputType="numberDecimal"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/munch_dark_green"
            android:textColorHint="@color/munch_stone"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginBottom="16dp"/>

        <!-- Email -->
        <EditText
            android:id="@+id/register_username"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:hint="Email*"
            android:inputType="textEmailAddress"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/munch_dark_green"
            android:textColorHint="@color/munch_stone"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginBottom="16dp"/>

        <!-- Password -->
        <EditText
            android:id="@+id/register_password"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:hint="Password*"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/munch_dark_green"
            android:textColorHint="@color/munch_stone"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginBottom="16dp"/>

        <!-- Confirm Password -->
        <EditText
            android:id="@+id/register_confirmpassword"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:hint="Confirm Password*"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/munch_dark_green"
            android:textColorHint="@color/munch_stone"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginBottom="24dp"/>

        <!-- Consent Checkbox -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <CheckBox
                android:id="@+id/consent_checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/consent_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="false"
                android:paddingStart="8dp"
                android:text="I agree to the Terms and Conditions"
                android:textColor="@color/macro_protein"
                android:textSize="14sp"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>

        <!-- Register Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/register_button"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:text="Create Account"
            android:textAllCaps="false"
            android:textColor="@color/munch_white"
            android:textSize="15sp"
            android:fontFamily="@font/outfit_semibold"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/munch_bangladesh_green"
            android:layout_marginBottom="16dp"/>

        <!-- To Login -->
        <TextView
            android:id="@+id/to_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Already have an account? Log in"
            android:textColor="@color/munch_bangladesh_green"
            android:textSize="14sp"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
</ScrollView>
