<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/munch_anti_flash_white"
    tools:context=".frontend.RegisterActivity">

    <!-- CENTERED CONTAINER -->
    <LinearLayout
        android:id="@+id/register_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Title -->
        <TextView
            android:id="@+id/register_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create your account"
            android:textColor="@color/munch_forest"
            android:textSize="24sp"
            android:fontFamily="@font/outfit_semibold"
            android:letterSpacing="0.02"
            android:layout_marginBottom="32dp" />

        <!-- Email -->
        <EditText
            android:id="@+id/register_username"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/munch_dark_green"
            android:textColorHint="@color/munch_stone"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginBottom="16dp"/>

        <!-- Password -->
        <EditText
            android:id="@+id/register_password"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/munch_dark_green"
            android:textColorHint="@color/munch_stone"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginBottom="16dp"/>

        <!-- Confirm Password -->
        <EditText
            android:id="@+id/register_confirmpassword"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:hint="Confirm Password"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/munch_dark_green"
            android:textColorHint="@color/munch_stone"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginBottom="24dp"/>

        <!-- Register Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/register_button"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:text="Create Account"
            android:textAllCaps="false"
            android:textColor="@color/munch_white"
            android:textSize="15sp"
            android:fontFamily="@font/outfit_semibold"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/munch_bangladesh_green"
            android:layout_marginBottom="16dp"/>

        <!-- To Login -->
        <TextView
            android:id="@+id/to_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Already have an account? Log in"
            android:textColor="@color/munch_bangladesh_green"
            android:textSize="14sp"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>


