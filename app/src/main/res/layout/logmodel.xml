<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true"
    app:cardBackgroundColor="@color/munch_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Top line: date • meal type -->
        <TextView
            android:id="@+id/row_top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="11/10/2025 • Dinner"
            android:textColor="@color/munch_forest"
            android:textSize="14sp"
            android:fontFamily="@font/outfit_semibold" />

        <!-- Bottom line: food name + amount -->
        <TextView
            android:id="@+id/row_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chicken — 150 g"
            android:textColor="@color/munch_stone"
            android:textSize="13sp"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>


