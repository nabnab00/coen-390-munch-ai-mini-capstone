<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/munch_anti_flash_white"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <!-- Header: Title -->
        <TextView
            android:id="@+id/main_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="4dp"
            android:fontFamily="@font/outfit_semibold"
            android:letterSpacing="0.02"
            android:text="Welcome back,"
            android:textColor="@color/munch_forest"
            android:textSize="24sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Settings Button -->
        <ImageButton
            android:id="@+id/to_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            android:contentDescription="@string/settings_button_desc"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:layout_marginTop="6dp"
            app:tint="@color/munch_forest"
            app:layout_constraintTop_toTopOf="@id/main_title"
            app:layout_constraintEnd_toEndOf="parent" />



        <!-- Date Text -->
        <TextView
            android:id="@+id/current_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monday, November 17"
            android:textColor="@color/munch_pistachio"
            android:textSize="12sp"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/main_title"
            app:layout_constraintStart_toStartOf="@id/main_title" />

        <androidx.cardview.widget.CardView
            android:id="@+id/main_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="28dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/munch_white"
            app:layout_constraintTop_toBottomOf="@id/current_date"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Header Row: Daily Goal | Macronutrients -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Daily Goal"
                        android:textColor="@color/munch_bangladesh_green"
                        android:textSize="24sp"
                        android:fontFamily="@font/outfit_bold"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Big Ring Centered -->
                <FrameLayout
                    android:layout_width="170dp"
                    android:layout_height="170dp"
                    android:layout_gravity="center">

                    <com.example.munchai.model.CircularProgressView
                        android:id="@+id/ring_calories"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cpv_backgroundColor="@color/munch_pistachio"
                        app:cpv_progressColor="@color/munch_bangladesh_green"
                        app:cpv_strokeWidth="20dp"
                        app:cpv_max="100"
                        app:cpv_progress="0" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_progress_center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="26sp"
                            android:textColor="@color/munch_bangladesh_green"
                            android:fontFamily="@font/outfit_semibold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Complete"
                            android:textSize="12sp"
                            android:textColor="@color/munch_stone"
                            android:fontFamily="@font/outfit_medium"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Stats Below Ring -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Goal"
                            android:textSize="11sp"
                            android:textColor="@color/munch_stone"
                            android:fontFamily="@font/outfit_medium" />

                        <TextView
                            android:id="@+id/tv_goal_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2000"
                            android:textSize="16sp"
                            android:textColor="@color/munch_dark_green"
                            android:fontFamily="@font/outfit_semibold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Intake"
                            android:textSize="11sp"
                            android:textColor="@color/munch_stone"
                            android:fontFamily="@font/outfit_medium" />

                        <TextView
                            android:id="@+id/tv_consumed_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="16sp"
                            android:textColor="@color/munch_dark_green"
                            android:fontFamily="@font/outfit_semibold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Left"
                            android:textSize="11sp"
                            android:textColor="@color/munch_stone"
                            android:fontFamily="@font/outfit_medium" />

                        <TextView
                            android:id="@+id/tv_remaining_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2000"
                            android:textSize="16sp"
                            android:textColor="@color/munch_dark_green"
                            android:fontFamily="@font/outfit_semibold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Space between stats & macro cards -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="20dp" />

                <!-- Protein Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/munch_anti_flash_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Row: Icon + Text -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/icon_protein"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:adjustViewBounds="true"
                                android:contentDescription="Protein Icon"
                                android:padding="4dp"
                                android:scaleType="fitCenter"
                                android:src="@drawable/protein_icon" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/outfit_semibold"
                                    android:text="Protein"
                                    android:textColor="@color/munch_dark_green"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/tv_protein_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/outfit_medium"
                                    android:text="0 / 150g"
                                    android:textColor="@color/munch_stone"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Progress bar -->
                        <ProgressBar
                            android:id="@+id/pb_protein"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="8dp"
                            android:max="100"
                            android:progress="0"
                            android:indeterminate="false"
                            android:progressTint="@color/macro_protein"
                            android:progressBackgroundTint="#E0E4EA"
                            android:scaleY="1.3" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Carbohydrates Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/munch_anti_flash_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Row: Icon + Text -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/icon_carbs"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/carbs_icon"
                                android:contentDescription="Carbs Icon"
                                android:padding="4dp"
                                android:adjustViewBounds="true"
                                android:scaleType="fitCenter" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Carbohydrates"
                                    android:textColor="@color/munch_dark_green"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit_semibold" />

                                <TextView
                                    android:id="@+id/tv_carbs_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 / 200g"
                                    android:textColor="@color/munch_stone"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/outfit_medium"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Progress bar -->
                        <ProgressBar
                            android:id="@+id/pb_carbs"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="8dp"
                            android:max="100"
                            android:progress="0"
                            android:indeterminate="false"
                            android:progressTint="@color/macro_carbs"
                            android:progressBackgroundTint="#E0E4EA"
                            android:scaleY="1.3" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Fats Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/munch_anti_flash_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Row: Icon + Text -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/icon_fats"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/fats_icon"
                                android:contentDescription="Fats Icon"
                                android:padding="4dp"
                                android:adjustViewBounds="true"
                                android:scaleType="fitCenter" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Fats"
                                    android:textColor="@color/munch_dark_green"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit_semibold" />

                                <TextView
                                    android:id="@+id/tv_fats_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 / 65g"
                                    android:textColor="@color/munch_stone"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/outfit_medium"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Progress bar -->
                        <ProgressBar
                            android:id="@+id/pb_fats"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="8dp"
                            android:max="100"
                            android:progress="0"
                            android:indeterminate="false"
                            android:progressTint="@color/macro_fat"
                            android:progressBackgroundTint="#E0E4EA"
                            android:scaleY="1.3" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>


            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <!-- Bottom Buttons -->
        <LinearLayout
            android:id="@+id/button_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            app:layout_constraintTop_toBottomOf="@id/main_card"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Primary action: Add Food -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/to_foodlog"
                android:layout_width="150dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:text="Add Food"
                android:textAllCaps="false"
                android:textColor="@color/munch_white"
                android:textSize="15sp"
                android:fontFamily="@font/outfit_semibold"
                android:background="@drawable/bg_add_food_button"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_add_circle"
                app:iconSize="30dp"
                app:iconPadding="12dp"
                app:iconGravity="textStart" />


            <!-- Secondary action: Food Log -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/to_history"
                android:layout_width="150dp"
                android:layout_height="63dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="Food Log"
                android:textAllCaps="false"
                android:textColor="@color/munch_bangladesh_green"
                android:textSize="15sp"
                android:fontFamily="@font/outfit_semibold"
                app:backgroundTint="@color/munch_white"
                app:strokeColor="@color/munch_bangladesh_green"
                app:strokeWidth="2dp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_book"
                app:iconTint="@null"
                app:iconSize="30dp"
                app:iconPadding="12dp"
                app:iconGravity="textStart" />


        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:id="@+id/footer_ai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Powered by  AI Technology"
            android:textSize="11sp"
            android:textColor="@color/munch_stone"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/button_row"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>

