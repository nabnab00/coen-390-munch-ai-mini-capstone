<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C19E7A"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <!-- Header: Welcome Text -->
        <TextView
            android:id="@+id/main_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome!"
            android:textColor="#6D4C41"
            android:textSize="32sp"
            android:fontFamily="@font/rammetto_one"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Settings Button -->
        <ImageButton
            android:id="@+id/to_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            android:contentDescription="@string/settings_button_desc"
            android:scaleType="centerInside"
            android:padding="8dp"
            app:tint="#6D4C41"
            app:layout_constraintTop_toTopOf="@id/main_title"
            app:layout_constraintBottom_toBottomOf="@id/main_title"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Date Text -->
        <TextView
            android:id="@+id/current_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monday, November 15"
            android:textColor="#9D7E63"
            android:textSize="14sp"
            android:fontFamily="@font/inter_medium"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/main_title"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Main White Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/main_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/current_date"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Header Row: Daily Goal | Macronutrients -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Daily Goal"
                        android:textColor="#6D4C41"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_semibold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Macronutrients"
                        android:textColor="#6D4C41"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_semibold"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Content Row: Ring | Macros -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- LEFT: Daily Goal Ring -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingEnd="8dp">

                        <!-- Single Ring with Center Text -->
                        <FrameLayout
                            android:layout_width="150dp"
                            android:layout_height="150dp">

                            <com.example.munchai.model.CircularProgressView
                                android:id="@+id/ring_calories"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                app:cpv_backgroundColor="#D9CEC1"
                                app:cpv_progressColor="#8D5A3A"
                                app:cpv_strokeWidth="20dp"
                                app:cpv_max="100"
                                app:cpv_progress="0" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:id="@+id/tv_progress_center"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textSize="28sp"
                                    android:textColor="#6D4C41"
                                    android:fontFamily="@font/inter_semibold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Complete"
                                    android:textSize="12sp"
                                    android:textColor="#9D7E63"
                                    android:fontFamily="@font/inter_medium"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </FrameLayout>

                        <!-- Stats Below Ring -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="16dp"
                            android:gravity="center">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Goal"
                                    android:textSize="10sp"
                                    android:textColor="#9D7E63"
                                    android:fontFamily="@font/inter_medium" />

                                <TextView
                                    android:id="@+id/tv_goal_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="2000"
                                    android:textSize="16sp"
                                    android:textColor="#6D4C41"
                                    android:fontFamily="@font/inter_semibold"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Consumed"
                                    android:textSize="10sp"
                                    android:textColor="#9D7E63"
                                    android:fontFamily="@font/inter_medium" />

                                <TextView
                                    android:id="@+id/tv_consumed_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="16sp"
                                    android:textColor="#6D4C41"
                                    android:fontFamily="@font/inter_semibold"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Remaining"
                                    android:textSize="10sp"
                                    android:textColor="#9D7E63"
                                    android:fontFamily="@font/inter_medium" />

                                <TextView
                                    android:id="@+id/tv_remaining_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="2000"
                                    android:textSize="16sp"
                                    android:textColor="#6D4C41"
                                    android:fontFamily="@font/inter_semibold"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- RIGHT: Macronutrients -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:gravity="center_vertical">

                        <!-- Protein Card -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginBottom="8dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#FFE4D6">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <!-- Row: icon + text -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <com.example.munchai.model.CircularProgressView
                                        android:id="@+id/ring_protein"
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        app:cpv_max="100"
                                        app:cpv_progress="0"
                                        app:cpv_backgroundColor="#FFE4D6"
                                        app:cpv_progressColor="#D2694C"
                                        app:cpv_strokeWidth="6dp" />

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:layout_marginStart="10dp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Protein"
                                            android:textColor="#6D4C41"
                                            android:textSize="11sp"
                                            android:fontFamily="@font/inter_semibold" />

                                        <TextView
                                            android:id="@+id/tv_protein_value"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="0 / 150g"
                                            android:textColor="#9D7E63"
                                            android:textSize="12sp"
                                            android:fontFamily="@font/inter_medium"
                                            android:layout_marginTop="2dp" />
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Carbohydrates Card -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginBottom="8dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#D6F0FF">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <!-- Row: icon + text -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <com.example.munchai.model.CircularProgressView
                                        android:id="@+id/ring_carbs"
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        app:cpv_max="100"
                                        app:cpv_progress="0"
                                        app:cpv_backgroundColor="#D6F0FF"
                                        app:cpv_progressColor="#3F51B5"
                                        app:cpv_strokeWidth="6dp" />

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:layout_marginStart="10dp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Carbohydrates"
                                            android:textColor="#6D4C41"
                                            android:textSize="11sp"
                                            android:fontFamily="@font/inter_semibold" />

                                        <TextView
                                            android:id="@+id/tv_carbs_value"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="0 / 200g"
                                            android:textColor="#9D7E63"
                                            android:textSize="12sp"
                                            android:fontFamily="@font/inter_medium"
                                            android:layout_marginTop="2dp" />
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Fats Card -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#D6F5D6">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <!-- Row: icon + text -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <com.example.munchai.model.CircularProgressView
                                        android:id="@+id/ring_fat"
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        app:cpv_max="100"
                                        app:cpv_progress="0"
                                        app:cpv_backgroundColor="#D6F5D6"
                                        app:cpv_progressColor="#4CAF50"
                                        app:cpv_strokeWidth="6dp" />

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:layout_marginStart="10dp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Fats"
                                            android:textColor="#6D4C41"
                                            android:textSize="11sp"
                                            android:fontFamily="@font/inter_semibold" />

                                        <TextView
                                            android:id="@+id/tv_fats_value"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="0 / 65g"
                                            android:textColor="#9D7E63"
                                            android:textSize="12sp"
                                            android:fontFamily="@font/inter_medium"
                                            android:layout_marginTop="2dp" />
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Buttons -->
        <LinearLayout
            android:id="@+id/button_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/main_card"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/to_foodlog"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="LOG MEAL"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="@font/inter_semibold"
                android:letterSpacing="0.05"
                app:backgroundTint="#6D4C41"
                app:cornerRadius="12dp"
                app:elevation="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/to_history"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Food Log"
                android:textColor="#6D4C41"
                android:textSize="14sp"
                android:fontFamily="@font/inter_semibold"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="12dp"
                app:strokeColor="#6D4C41"
                app:strokeWidth="2dp"
                app:elevation="2dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/to_test"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="View Gemini Testing"
            android:textColor="#6D4C41"
            android:textSize="14sp"
            android:fontFamily="@font/inter_medium"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="12dp"
            app:strokeColor="#6D4C41"
            app:strokeWidth="2dp"
            app:elevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/button_row"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
