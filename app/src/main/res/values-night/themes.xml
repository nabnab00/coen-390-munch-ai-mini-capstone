<resources
    xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.MunchAI" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/brown_primary</item>
        <item name="colorOnPrimary">@color/brown_onPrimary</item>

        <!-- Secondary color -->
        <item name="colorSecondary">@color/brown_secondary</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/brown_background</item>
        <item name="colorOnBackground">@color/brown_onBackground</item>

        <!-- Optional: status bar / navigation bar -->
        <item name="android:statusBarColor">@color/brown_primary</item>
        <item name="android:navigationBarColor">@color/brown_primary</item>
    </style>

    <style name="Theme.MunchAI" parent="Base.Theme.MunchAI" />
</resources>
