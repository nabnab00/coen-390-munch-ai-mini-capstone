<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- DARK THEME -->
    <style name="Base.Theme.MunchAI" parent="Theme.Material3.Dark.NoActionBar">

        <!-- Primary brand (a bit brighter in dark) -->
        <item name="colorPrimary">@color/munch_caribbean_green</item>
        <item name="colorOnPrimary">@color/munch_rich_black</item>
        <item name="colorPrimaryContainer">@color/munch_forest</item>
        <item name="colorOnPrimaryContainer">@color/munch_anti_flash_white</item>

        <!-- Secondary / accents -->
        <item name="colorSecondary">@color/munch_mountain_meadow</item>
        <item name="colorOnSecondary">@color/munch_rich_black</item>
        <item name="colorSecondaryContainer">@color/munch_pine</item>
        <item name="colorOnSecondaryContainer">@color/munch_anti_flash_white</item>

        <!-- Backgrounds & surfaces -->
        <item name="android:colorBackground">@color/munch_dark_green</item>
        <item name="colorOnBackground">@color/munch_anti_flash_white</item>

        <item name="colorSurface">@color/munch_pine</item>
        <item name="colorOnSurface">@color/munch_anti_flash_white</item>

        <!-- Status / nav bars -->
        <item name="android:statusBarColor">@color/munch_rich_black</item>
        <item name="android:navigationBarColor">@color/munch_rich_black</item>

        <!-- Default background in dark mode -->
        <item name="android:windowBackground">@color/munch_dark_green</item>
    </style>

    <!-- App theme alias -->
    <style name="Theme.MunchAI" parent="Base.Theme.MunchAI" />

</resources>

