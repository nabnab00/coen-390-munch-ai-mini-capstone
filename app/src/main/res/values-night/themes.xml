<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- DARK THEME -->
    <style name="Base.Theme.MunchAI" parent="Theme.Material3.Dark.NoActionBar">

        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/munch_forest</item>
        <item name="colorOnPrimaryContainer">@color/munch_anti_flash_white</item>

        <!-- Secondary / accents -->
        <item name="colorSecondary">@color/munch_mountain_meadow</item>
        <item name="colorOnSecondary">@color/munch_rich_black</item>
        <item name="colorSecondaryContainer">@color/munch_pine</item>
        <item name="colorOnSecondaryContainer">@color/munch_anti_flash_white</item>

        <item name="colorOnBackground">@color/colorOnBackground</item>

        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>

        <!-- System bars / window -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
        <item name="android:windowBackground">@color/colorBackground</item>

        <!-- Make sure icons/text in system bars expect dark background -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

    </style>

    <!-- App theme alias -->
    <style name="Theme.MunchAI" parent="Base.Theme.MunchAI" />

</resources>


